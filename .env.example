# --- INFRASTRUCTURE (Required for Railway/Render) ---
DATABASE_URL=postgresql://user:password@host:port/dbname
REDIS_URL=redis://host:port/0

# --- AI CORE (Required) ---
OPENAI_API_KEY=sk-proj-....
HF_TOKEN=hf_.... # Required for Pyannote diarization

# --- DEPLOYMENT SETTINGS ---
# Environment: production or development
APP_ENV=production

# CORS: Your live frontend URL (e.g., https://brevity-ai.vercel.app)
BACKEND_CORS_ORIGINS=https://your-frontend-url.vercel.app,http://localhost:5173

# --- Optional Extras ---
PROJECT_NAME="Brevity AI"
DEBUG=False
